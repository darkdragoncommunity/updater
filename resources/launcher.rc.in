#include <winver.h>

#define IDI_APP_ICON 101

IDI_APP_ICON ICON "@CMAKE_CURRENT_SOURCE_DIR@/assets/app.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @LAUNCHER_VERSION_MAJOR@,@LAUNCHER_VERSION_MINOR@,@LAUNCHER_VERSION_BUILD@,@LAUNCHER_VERSION_REVISION@
 PRODUCTVERSION @LAUNCHER_VERSION_MAJOR@,@LAUNCHER_VERSION_MINOR@,@LAUNCHER_VERSION_BUILD@,@LAUNCHER_VERSION_REVISION@
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "@LAUNCHER_COMPANY_NAME@\0"
            VALUE "FileDescription", "@LAUNCHER_FILE_DESCRIPTION@\0"
            VALUE "FileVersion", "@LAUNCHER_VERSION_STRING@\0"
            VALUE "InternalName", "@LAUNCHER_INTERNAL_NAME@\0"
            VALUE "OriginalFilename", "@LAUNCHER_ORIGINAL_FILENAME@\0"
            VALUE "ProductName", "@LAUNCHER_PRODUCT_NAME@\0"
            VALUE "ProductVersion", "@LAUNCHER_VERSION_STRING@\0"
            VALUE "LegalCopyright", "@LAUNCHER_COPYRIGHT@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
